generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

/// Trạng thái của Issue trên Kanban board
enum IssueStatus {
  TODO
  IN_PROGRESS
  TEST
  DONE
}

/// Phân loại Issue theo cấp độ
enum IssueType {
  EPIC
  STORY
  TASK
}

// ============================================================
// Models
// ============================================================

/// Người dùng hệ thống
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  assignedIssues Issue[] @relation("Assignee")
  reportedIssues Issue[] @relation("Reporter")

  @@map("users")
}

/// Dự án chứa các Issue
model Project {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique /// Mã viết tắt dự án (VD: "PROJ")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  issues Issue[]

  @@map("projects")
}

/// Đơn vị công việc: Epic, Story hoặc Task
model Issue {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        IssueType   @default(TASK)
  status      IssueStatus @default(TODO)
  priority    Int         @default(0) /// 0 = Lowest … 4 = Highest
  orderIndex  Int         @default(0) @map("order_index") /// Vị trí sắp xếp trên board

  // Foreign keys
  projectId  String  @map("project_id")
  assigneeId String? @map("assignee_id")
  reporterId String? @map("reporter_id")
  parentId   String? @map("parent_id") /// Cho phép Epic → Story → Task

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter User?   @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  parent   Issue?  @relation("SubIssues", fields: [parentId], references: [id], onDelete: SetNull)
  children Issue[] @relation("SubIssues")

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@map("issues")
}
